# =============================================================================
# Magnetic Marketing — environment variables
# =============================================================================
# Kopieer dit bestand naar `.env.local` voor lokale ontwikkeling.
# Zet diezelfde variabelen ook in Vercel onder Project → Settings → Environment Variables.
# .env.local en .env worden NIET gecommit (zie .gitignore).
# =============================================================================

# Resend API key voor het contactformulier
# Haal op via https://resend.com → API Keys → Create API Key
RESEND_API_KEY=

# Optioneel: afzender-adres voor uitgaande mails. Moet een geverifieerd domein in Resend zijn.
# Voorbeeld: "Magnetic Marketing <noreply@marketing-magnetic.nl>"
RESEND_FROM=
